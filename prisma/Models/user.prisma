model User {
    id String @id @default(uuid())
    firstName  String
    lastName   String
    email String @unique
    password String
    role Role   @default(customer)
    isVerified Boolean @default(false)
    orders   Order[]
    products Product[]
    address Address[]
    cart  Cart?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum Role {
    customer
    seller
    admin
}