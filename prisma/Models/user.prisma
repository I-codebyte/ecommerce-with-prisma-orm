model User {
    id String @id @default(uuid())
    first_name  String
    last_name   String
    email String @unique
    password String
    role Role   @default(customer)
    is_verified Boolean @default(false)
    orders   Order[]
    products Product[]
    address Address[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum Role {
    customer
    seller
    admin
}